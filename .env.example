TALLY_WEBHOOK_SECRET=your_tally_secret_here

WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v22.0
WA_ADMIN_NUMBER=+1234567890

GOOGLE_SHEET_ID=your_spreadsheet_id
GOOGLE_SHEET_TAB=Submissions
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=credentials.json

WHATSAPP_TEMPLATE_NAME=job_post_notification
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_WEBHOOK_VERIFY_TOKEN=my_secure_token
ENABLE_WHATSAPP_SEND=true
ENABLE_SHEETS_LOG=true
MAX_MESSAGE_CHARS=3500
DEBUG_TALLY_MAPPING=false

# OpenAI Config (New Long-Form Intake)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
ENABLE_OPENAI_PARSE=true
